{
  "name": "vedaai-backend",
  "version": "1.0.0",
  "description": "AI Assessment Creator backend built with Express, TypeScript, MongoDB, Redis, BullMQ and WebSockets",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src -e ts --exec tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "bullmq": "^5.8.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "groq-sdk": "^0.3.3",
    "ioredis": "^5.4.1",
    "mongoose": "^8.3.1",
    "pdfkit": "^0.15.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/pdfkit": "^0.13.4",
    "@types/ws": "^8.5.10",
    "nodemon": "^3.1.0",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
