# Port for the Express API server to listen on
PORT=5000

# MongoDB Connection URI (local development database)
# Default assumes a local MongoDB running natively or via Docker on port 27017
MONGODB_URI=mongodb://localhost:27017/vedaai

# Redis Server configuration for BullMQ task queues
REDIS_HOST=localhost
REDIS_PORT=6379

# OPTIONAL: Unified Redis Connection String (used primarily in cloud deployments like Render)
# REDIS_URL=redis://localhost:6379

# Groq Cloud API Key credentials (REQUIRED for live AI question paper generation)
# Get your API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
